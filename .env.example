# Open Brain configuration

# Server
BRAIN_HOST=0.0.0.0
BRAIN_PORT=8766

# PostgreSQL + PGVector
USE_POSTGRES=true
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DB=braindb
PGVECTOR_USER=brainuser
PGVECTOR_PASSWORD=

# Embeddings (LM Studio / OpenAI-compatible)
EMBEDDING_API_URL=http://localhost:1234/v1/embeddings
EMBEDDING_MODEL=qwen3-embedding-0.6b-mxfp8

# Obsidian (optional)
# OBSIDIAN_VAULT=/path/to/your/vault

# Logging
LOG_LEVEL=INFO
